<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Register – Sole Traders</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
  <link rel="stylesheet" href="/css/mainStyle.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>

<body class="auth-page">

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-light bg-light">
  <div class="container">
    <a class="navbar-brand" href="/">Sole Traders</a>
    <div class="ms-auto">
      <a href="/login" class="btn btn-outline-primary btn-sm">Login</a>
    </div>
  </div>
</nav>

<!-- CENTERED REGISTER CARD -->
<div class="auth-shell">
  <div class="container">
    <div class="row justify-content-center align-items-center auth-row">
      <div class="col-md-7 col-lg-5">

        <div class="card auth-card shadow-lg">
          <div class="card-body p-4">

            <h3 class="mb-4 text-center text-white">Register as a Trader</h3>

            <form method="POST" action="/register" id="registerForm" novalidate>

              <div class="mb-3">
                <label class="form-label text-white">Full Name</label>
                <input type="text" class="form-control" name="name" required>
                <div class="invalid-feedback">Please enter your name.</div>
              </div>

              <div class="mb-3">
                <label class="form-label text-white">Username</label>
                <input
                  type="text"
                  class="form-control"
                  id="username"
                  name="username"
                  required
                >
                <div class="invalid-feedback">
                  Username already in use
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label text-white">Email</label>
                <input
                  type="email"
                  class="form-control"
                  id="email"
                  name="email"
                  required
                >
                <div class="invalid-feedback" id="emailFormatError">
                  Enter a valid email address
                </div>
                <div class="invalid-feedback d-none" id="emailTakenError">
                  Email already in use
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label text-white">Password</label>
                <input
                  type="password"
                  class="form-control"
                  name="password"
                  required
                  minlength="6"
                >
                <div class="invalid-feedback">
                  Password must be at least 6 characters.
                </div>
                <div class="form-text auth-hint">Minimum 6 characters</div>
              </div>

              <div class="mb-3">
                <label class="form-label text-white">Trade Type</label>
                <select class="form-select" name="tradeType" required>
                  <option value="">Select…</option>
                  <option>Plumbing</option>
                  <option>Electrical</option>
                  <option>Cleaning</option>
                  <option>Carpentry</option>
                  <option>Gardening</option>
                  <option>Painting</option>
                </select>
                <div class="invalid-feedback">
                  Please select a trade type.
                </div>
              </div>

              <div class="mb-4">
                <label class="form-label text-white">Region / Town</label>
                <input type="text" class="form-control" name="region" required>
                <div class="invalid-feedback">
                  Please enter your region or town.
                </div>
              </div>

              <button
                type="submit"
                class="btn btn-primary w-100"
                id="submitBtn"
                disabled
              >
                Register
              </button>

              <hr class="auth-divider">

              <p class="text-center mb-0 auth-help">
                Already have an account?
                <a href="/login">Login</a>
              </p>

            </form>

          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
(() => {

  const form = document.getElementById('registerForm');

  const nameInput = form.querySelector('input[name="name"]');
  const usernameInput = document.getElementById('username');
  const emailInput = document.getElementById('email');
  const passwordInput = form.querySelector('input[name="password"]');
  const tradeTypeInput = form.querySelector('select[name="tradeType"]');
  const regionInput = form.querySelector('input[name="region"]');
  const submitBtn = document.getElementById('submitBtn');

  const emailFormatError = document.getElementById('emailFormatError');
  const emailTakenError = document.getElementById('emailTakenError');

  let usernameOk = false;
  let emailOk = false;

  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function fieldsComplete() {
    return (
      nameInput.value.trim() !== "" &&
      passwordInput.value.trim().length >= 6 &&
      tradeTypeInput.value !== "" &&
      regionInput.value.trim() !== ""
    );
  }

  function updateSubmitState() {
    submitBtn.disabled = !(fieldsComplete() && usernameOk && emailOk);
  }

  async function checkAvailability() {

    const username = usernameInput.value.trim();
    const email = emailInput.value.trim();

    usernameOk = false;
    emailOk = false;

    if (!email) {
      updateSubmitState();
      return;
    }

    if (!emailRegex.test(email)) {
      emailInput.classList.add('is-invalid');
      emailInput.classList.remove('is-valid');
      emailFormatError.classList.remove('d-none');
      emailTakenError.classList.add('d-none');
      updateSubmitState();
      return;
    }

    emailFormatError.classList.add('d-none');

    const params = new URLSearchParams();
    if (username) params.append('username', username);
    if (email) params.append('email', email);

    try {

      const res = await fetch(`/auth/check-availability?${params}`);
      const data = await res.json();

      if (username) {
        usernameOk = data.usernameAvailable;
        usernameInput.classList.toggle('is-valid', usernameOk);
        usernameInput.classList.toggle('is-invalid', !usernameOk);
      }

      if (email) {
        emailOk = data.emailAvailable;
        emailInput.classList.toggle('is-valid', emailOk);
        emailInput.classList.toggle('is-invalid', !emailOk);
        emailTakenError.classList.toggle('d-none', emailOk);
      }

      updateSubmitState();

    } catch (err) {
      console.error(err);
    }
  }

  let debounceTimer;

  function debounceCheck() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(checkAvailability, 400);
  }

  usernameInput.addEventListener('input', debounceCheck);
  emailInput.addEventListener('input', debounceCheck);

  nameInput.addEventListener('input', updateSubmitState);
  passwordInput.addEventListener('input', updateSubmitState);
  tradeTypeInput.addEventListener('change', updateSubmitState);
  regionInput.addEventListener('input', updateSubmitState);

  form.addEventListener('submit', e => {

    form.classList.add('was-validated');

    if (!fieldsComplete() || !usernameOk || !emailOk) {
      e.preventDefault();
    }

  });

})();
</script>

</body>
</html>